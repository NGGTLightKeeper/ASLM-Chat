{
    "fileVersion": 1,
    "id": "aslm-ui",
    "name": "ASLM UI",
    "description": "ASLM UI Module.",
    "version": "0.0.1",
    "author": "NGGT-ASLM",
    "type": "ui",
    "hasPage": true,
    "icon": "icon.png",
    "sidebarIcon": "sidebar_icon.png",
    "source": {
        "type": "github",
        "repo": "NGGTLightKeeper/ASLM-UI"
    },
    "dependencies": {
        "engines": [
            {
                "id": "python-runtime",
                "libraries": [
                    "argon2-cffi",
                    "django==6.0.2",
                    "django-cors-headers",
                    "martor",
                    "whitenoise"
                ]
            },
            {
                "id": "ollama-service"
            }
        ]
    },
    "commands": {
        "firstRun": [
            {
                "name": "First Run Setup",
                "description": "Generates settings.json and applies database migrations",
                "engine": "python-runtime",
                "exec": "main.py first_run"
            }
        ],
        "run": [
            {
                "name": "Start UI Server",
                "description": "Launches the Django development server",
                "engine": "python-runtime",
                "exec": "main.py runserver"
            }
        ]
    },
    "settings": [
        {
            "key": "port",
            "name": "Server Port",
            "description": "Port the UI server listens on",
            "type": "port",
            "default": "8000",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key port",
            "setExec": "main.py set_setting --key port --value {value}"
        },
        {
            "key": "ollama_enabled",
            "name": "Ollama Status",
            "description": "Whether the Ollama inference service is active",
            "type": "bool",
            "default": "false",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama_enabled",
            "setExec": "main.py set_setting --key ollama_enabled --value {value}"
        },
        {
            "key": "ollama_port",
            "name": "Ollama Port",
            "description": "Port that the local Ollama service listens on",
            "type": "port",
            "default": "11434",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama_port",
            "setExec": "main.py set_setting --key ollama_port --value {value}"
        }
    ],
    "status": {
        "installed": false,
        "enabled": false,
        "firstRunCompleted": false
    }
}